---
import { getCollection } from 'astro:content';
import AdSlot from '../components/AdSlot.astro';
import PostPreviewCard from '../components/PostPreviewCard.astro';
import SidebarCard from '../components/SidebarCard.astro';
import ClassicShell from '../layouts/ClassicShell.astro';
import { SITE_DESCRIPTION, SITE_KEYWORDS } from '../consts';
import { SITE_PRIORITY_CLUSTERS, SITE_UPDATE_PLAYBOOK } from '../sitePlan';
import { sortPosts } from '../utils/content';

const posts = sortPosts(await getCollection('blog'));
const [featuredPost, ...morePosts] = posts;
---

<ClassicShell
	title="AI Prompt Gear | Prompt Systems, Agent Workflows, and Tool Intelligence"
	description={SITE_DESCRIPTION}
	pageTitle="AI prompt systems, agent workflows, and software-intent editorial that compounds"
	pageIntro="AI Prompt Gear is designed as a premium English-language publication for operators, consultants, and software buyers. The framework separates durable topic clusters, future sponsor inventory, and high-intent comparison pages so the brand can scale into a trusted reference business."
	introLabel="AI Prompt Gear"
	keywords={[...SITE_KEYWORDS, 'AI workflow publisher', 'prompt systems hub', 'AI tool intelligence']}
>
	<Fragment slot="left-rail">
		<SidebarCard title="Start Here" eyebrow="Core Routes">
			<ul>
				<li><a href="/categories/prompt-systems/">Prompt Systems</a> for reusable frameworks and team libraries</li>
				<li><a href="/categories/agent-workflows/">Agent Workflows</a> for reporting, support, and operations</li>
				<li><a href="/categories/tool-evaluation/">Tool Evaluation</a> for software shortlists and buying intent</li>
			</ul>
		</SidebarCard>

		<SidebarCard title="High-Value Traffic" eyebrow="Why It Matters">
			<p>
				The goal is not generic AI news. The goal is evergreen operator knowledge that attracts
				readers who are close to implementing, buying, or standardizing AI tooling.
			</p>
		</SidebarCard>
	</Fragment>

	<section class="hero-panel">
		<div class="hero-grid">
			<div>
				<p class="eyebrow">Editorial Engine</p>
				<h2>Built for reusable knowledge, not disposable AI chatter</h2>
				<p>
					This site is meant to win by publishing assets that teams revisit: prompt libraries,
					role-based workflows, AI stack comparisons, and implementation playbooks that remain useful
					after the news cycle moves on.
				</p>
				<div class="chip-row">
					<a class="taxonomy-link" href="/categories/prompt-systems/">Prompt Systems</a>
					<a class="taxonomy-link" href="/categories/agent-workflows/">Agent Workflows</a>
					<a class="taxonomy-link" href="/categories/tool-evaluation/">Tool Evaluation</a>
					<a class="taxonomy-link" href="/blog/">Archive</a>
				</div>
			</div>

			<div class="hero-aside">
				<article class="detail-card">
					<p class="section-kicker">Reader Intent</p>
					<h3>Who becomes valuable here</h3>
					<ul class="signal-list">
						<li>Operators standardizing AI inside teams</li>
						<li>Consultants packaging repeatable workflows</li>
						<li>Buyers evaluating copilots, assistants, and prompt tooling</li>
					</ul>
				</article>

				<article class="detail-card">
					<p class="section-kicker">Long-Term Asset</p>
					<h3>What keeps ranking</h3>
					<p>
						Role-specific prompt packs, implementation checklists, and tool intelligence pages are
						more durable than reactive commentary and build a stronger long-tail search moat.
					</p>
				</article>
			</div>
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Editorial Products</p>
				<h2>Three lanes that can become a real content business</h2>
			</div>
		</div>
		<div class="hub-grid">
			<article class="hub-card">
				<h4><a href="/categories/prompt-systems/">Prompt Systems</a></h4>
				<p>Reusable frameworks, role packs, and standardized prompt assets that age well and invite revisits.</p>
			</article>
			<article class="hub-card">
				<h4><a href="/categories/agent-workflows/">Agent Workflows</a></h4>
				<p>Process-driven AI content for support, research, onboarding, reporting, and internal operating systems.</p>
			</article>
			<article class="hub-card">
				<h4><a href="/categories/tool-evaluation/">Tool Evaluation</a></h4>
				<p>Commercial-intent comparisons for teams choosing platforms, assistants, model tooling, and SaaS stacks.</p>
			</article>
		</div>
	</section>

	{featuredPost ? (
		<>
			<section class="section-block">
				<div class="section-head">
					<div>
						<p class="eyebrow">Lead Workflow</p>
						<h2>Featured AI operations entry</h2>
					</div>
				</div>
				<PostPreviewCard post={featuredPost} featured={true} />
			</section>

			<AdSlot
				slotId="home-saas-leaderboard"
				format="banner"
				headline="Reserved AI software leaderboard"
				note="This center-column unit is reserved for future direct-sold software sponsors, newsletter placements, or house campaigns tied to the best tool-intent pages."
			/>
		</>
	) : (
		<section class="section-block">
			<div class="section-head">
				<div>
					<p class="eyebrow">Lead Workflow</p>
					<h2>No posts published yet</h2>
				</div>
			</div>
			<p>Seed this column with workflow kits, prompt libraries, and software comparison pages first.</p>
		</section>
	)}

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Why This Can Win</p>
				<h2>SEO and revenue logic baked into the structure</h2>
			</div>
		</div>
		<div class="detail-grid">
			<article class="detail-card">
				<p class="section-kicker">Search Moat</p>
				<h3>Repeatable problem framing</h3>
				<p>Search-friendly titles and category hubs keep the site aligned with recurring job-to-be-done queries instead of trend spikes.</p>
			</article>
			<article class="detail-card">
				<p class="section-kicker">Retention</p>
				<h3>Readers come back for systems</h3>
				<p>Prompt stacks and workflow libraries are reference assets, which gives the brand a better chance at repeat visits and newsletter growth.</p>
			</article>
			<article class="detail-card">
				<p class="section-kicker">Monetization</p>
				<h3>Higher-value inventory later</h3>
				<p>Tool comparisons and operator playbooks naturally support direct software sponsors, premium template bundles, and expert resource offers.</p>
			</article>
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Editorial Engine</p>
				<h2>The strategy layer is now part of the site, not hidden behind it</h2>
			</div>
		</div>
		<div class="detail-grid">
			<article class="detail-card">
				<p class="section-kicker">Topic Map</p>
				<h3><a href="/topics/">See the long-term cluster plan</a></h3>
				<p>
					The current highest-priority cluster is <strong>{SITE_PRIORITY_CLUSTERS[0].title}</strong>,
					which is exactly the kind of operator workflow theme that can grow into a durable traffic engine.
				</p>
			</article>
			<article class="detail-card">
				<p class="section-kicker">Methodology</p>
				<h3><a href="/methodology/">Read how the archive should be built</a></h3>
				<p>
					The methodology page defines what gets published, what gets avoided, and how comparison-heavy
					pages should stay trustworthy over time.
				</p>
			</article>
			<article class="detail-card">
				<p class="section-kicker">Cadence</p>
				<h3>{SITE_UPDATE_PLAYBOOK[0].title}</h3>
				<p>{SITE_UPDATE_PLAYBOOK[0].summary}</p>
			</article>
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Archive Stream</p>
				<h2>Recent prompt and agent entries</h2>
			</div>
		</div>

		<div class="post-stream">
			{morePosts.length > 0 ? (
				morePosts.map((post) => <PostPreviewCard post={post} />)
			) : (
				<p>Use this stream for long-tail prompt posts that continuously attract search and affiliate-intent traffic.</p>
			)}
		</div>
	</section>

	<AdSlot
		slotId="home-mobile-newsletter"
		format="mobile"
		headline="Reserved mobile sponsor slot"
		note="On smaller screens this compact unit can later support a newsletter promotion, AI tool CTA, or premium house offer without disrupting the reading flow."
	/>
</ClassicShell>
