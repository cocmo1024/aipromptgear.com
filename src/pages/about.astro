---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`About | ${SITE.title}`}>
  <Header />
  <Main pageTitle="About" pageDesc={`About ${SITE.title}`}>
    <div class="app-prose max-w-app">
      <p>
        AI Prompt Gear is an independent English-language publication covering prompt systems, agent workflows, and practical AI tool evaluation.
      </p>
      <p>
        The editorial goal is to publish clear, durable content that helps readers understand how modern AI tooling is used in repeatable work.
      </p>
    </div>
  </Main>
  <Footer />
</Layout>
