---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import SidebarCard from '../components/SidebarCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	pageTitle?: string;
	pageIntro?: string;
	introLabel?: string;
	showPageIntro?: boolean;
	keywords?: string[];
	pageType?: "website" | "article";
	robots?: string;
	publishedTime?: string;
	modifiedTime?: string;
	section?: string;
	tags?: string[];
	schemas?: Record<string, unknown>[];
	breadcrumbs?: { name: string; path: string }[];
}

const {
	title = SITE_TITLE,
	description = SITE_DESCRIPTION,
	image,
	pageTitle = SITE_TITLE,
	pageIntro = SITE_DESCRIPTION,
	introLabel = "Front Page",
	showPageIntro = true,
	keywords = [],
	pageType = "website",
	robots,
	publishedTime,
	modifiedTime,
	section,
	tags = [],
	schemas = [],
	breadcrumbs = [],
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={image}
			keywords={keywords}
			pageType={pageType}
			robots={robots}
			publishedTime={publishedTime}
			modifiedTime={modifiedTime}
			section={section}
			tags={tags}
			schemas={schemas}
			breadcrumbs={breadcrumbs}
		/>
	</head>
	<body>
		<div class="site-frame">
			<Header />

			<div class="site-grid">
				<aside class="left-rail">
					<div class="rail-stack">
						<SidebarCard title="Search Moat" eyebrow="Pillars">
							<ul>
								<li>Prompt systems that can rank for reusable workflows</li>
								<li>Agent operations pages tied to daily team use cases</li>
								<li>Tool intelligence that captures software buying intent</li>
							</ul>
						</SidebarCard>

						<SidebarCard title="High-Value Visitors" eyebrow="Traffic Quality" compact={true}>
							<ul>
								<li>Operators trying to standardize AI work inside teams</li>
								<li>Consultants and builders comparing workflow tooling</li>
								<li>Readers close to software evaluation or template purchase</li>
							</ul>
						</SidebarCard>

						<slot name="left-rail" />
					</div>
				</aside>

				<main class="content-column">
					<div class="content-stack">
						{
							showPageIntro && (
								<section class="page-intro">
									<p class="eyebrow">{introLabel}</p>
									<h1>{pageTitle}</h1>
									<p>{pageIntro}</p>
								</section>
							)
						}

						<slot />
					</div>
				</main>

				<aside class="right-rail">
					<div class="rail-stack">
						<AdSlot
							slotId="rail-tool-sponsor"
							format="rectangle"
							headline="Reserved workflow sponsor"
							note="Keep this premium rectangle as a placeholder until the site has enough search depth to justify direct-sold AI tool, API, or workflow software campaigns."
						/>

						<SidebarCard title="Activation Logic" eyebrow="Commercial Plan">
							<p>
								This rail is designed for future direct partnerships, not early clutter. Prompt
								libraries, workflow breakdowns, and comparison pages create the kind of mid-funnel
								intent that supports cleaner, higher-value sponsorships later on.
							</p>
						</SidebarCard>

						<AdSlot
							slotId="rail-affiliate-tower"
							format="tower"
							headline="Later-stage comparison tower"
							note="Reserve this tall unit for future software comparison creatives, premium template bundles, or high-EPC house campaigns once the content library matures."
						/>

						<slot name="right-rail" />
					</div>
				</aside>
			</div>

			<Footer />
		</div>
	</body>
</html>
