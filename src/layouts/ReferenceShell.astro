---
import '../styles/global.css';
import { siteMeta } from '../utils/site-meta.mjs';

interface Breadcrumb {
	label: string;
	href?: string;
}

interface Props {
	title: string;
	description: string;
	breadcrumbs?: Breadcrumb[];
	eyebrow?: string;
	canonicalPath?: string;
}

const {
	title,
	description,
	breadcrumbs = [],
	eyebrow = 'AI Prompt Gear',
	canonicalPath = Astro.url.pathname,
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, `${siteMeta.siteUrl}/`).toString();
const pageTitle = `${title} | ${siteMeta.name}`;
const imageVariants =
	Array.isArray(siteMeta.richResultImages) && siteMeta.richResultImages.length
		? siteMeta.richResultImages
		: [
				{
					path: siteMeta.ogImagePath,
					width: 1200,
					height: 630,
					alt: siteMeta.ogImageAlt,
				},
			];
const primaryImage = imageVariants[0];
const imageUrl = new URL(primaryImage.path, `${siteMeta.siteUrl}/`).toString();
const imageType = imageUrl.endsWith('.svg') ? 'image/svg+xml' : 'image/png';
const twitterSite = siteMeta.xUrl ? `@${new URL(siteMeta.xUrl).pathname.replace(/^\/+/, '').split('/')[0]}` : undefined;
const logoUrl = new URL(siteMeta.icon512Path, `${siteMeta.siteUrl}/`).toString();
const webpageId = `${canonicalUrl}#webpage`;
const articleId = `${canonicalUrl}#article`;
const author = siteMeta.editorialEntities?.['editorial-desk'];
const editor = siteMeta.editorialEntities?.['review-desk'];
const imageObjects = imageVariants.map((image, index) => ({
	'@context': 'https://schema.org',
	'@type': 'ImageObject',
	'@id': `${canonicalUrl}#primaryimage-${index + 1}`,
	url: new URL(image.path, `${siteMeta.siteUrl}/`).toString(),
	contentUrl: new URL(image.path, `${siteMeta.siteUrl}/`).toString(),
	width: image.width,
	height: image.height,
	caption: image.alt ?? siteMeta.ogImageAlt,
}));
const breadcrumbId = `${canonicalUrl}#breadcrumb`;
const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		'@id': `${siteMeta.siteUrl}/#organization`,
		name: siteMeta.name,
		alternateName: Array.from(new Set([siteMeta.shortName, siteMeta.domain].filter(Boolean))),
		url: `${siteMeta.siteUrl}/`,
		description: siteMeta.description,
		email: siteMeta.email,
		sameAs: Array.from(
			new Set([...(siteMeta.sameAs ?? []), ...(siteMeta.repoUrl ? [siteMeta.repoUrl] : [])])
		),
		publishingPrinciples: new URL(
			siteMeta.publishingPrinciplesPath ?? '/editorial-policy/',
			`${siteMeta.siteUrl}/`
		).toString(),
		logo: {
			'@type': 'ImageObject',
			'@id': `${siteMeta.siteUrl}/#logo`,
			url: logoUrl,
			contentUrl: logoUrl,
			width: 512,
			height: 512,
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		'@id': `${siteMeta.siteUrl}/#website`,
		url: `${siteMeta.siteUrl}/`,
		name: siteMeta.name,
		alternateName: [siteMeta.domain],
		description: siteMeta.description,
		inLanguage: siteMeta.languageTag,
		publisher: { '@id': `${siteMeta.siteUrl}/#organization` },
		publishingPrinciples: new URL(
			siteMeta.publishingPrinciplesPath ?? '/editorial-policy/',
			`${siteMeta.siteUrl}/`
		).toString(),
	},
	...(author
		? [
				{
					'@context': 'https://schema.org',
					'@type': 'Organization',
					'@id': `${new URL(author.path, `${siteMeta.siteUrl}/`).toString()}#profile`,
					name: author.name,
					description: author.description,
					url: new URL(author.path, `${siteMeta.siteUrl}/`).toString(),
					memberOf: { '@id': `${siteMeta.siteUrl}/#organization` },
					knowsAbout: author.expertise,
				},
			]
		: []),
	...(editor
		? [
				{
					'@context': 'https://schema.org',
					'@type': 'Organization',
					'@id': `${new URL(editor.path, `${siteMeta.siteUrl}/`).toString()}#profile`,
					name: editor.name,
					description: editor.description,
					url: new URL(editor.path, `${siteMeta.siteUrl}/`).toString(),
					memberOf: { '@id': `${siteMeta.siteUrl}/#organization` },
					knowsAbout: editor.expertise,
				},
			]
		: []),
	...imageObjects,
	{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		'@id': webpageId,
		name: title,
		description,
		url: canonicalUrl,
		inLanguage: siteMeta.languageTag,
		isPartOf: { '@id': `${siteMeta.siteUrl}/#website` },
		primaryImageOfPage: { '@id': imageObjects[0]['@id'] },
		...(author ? { author: { '@id': `${new URL(author.path, `${siteMeta.siteUrl}/`).toString()}#profile` } } : {}),
		...(editor ? { editor: { '@id': `${new URL(editor.path, `${siteMeta.siteUrl}/`).toString()}#profile` } } : {}),
		...(breadcrumbs.length ? { breadcrumb: { '@id': breadcrumbId } } : {}),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Article',
		'@id': articleId,
		headline: title,
		description,
		url: canonicalUrl,
		inLanguage: siteMeta.languageTag,
		mainEntityOfPage: { '@id': webpageId },
		isAccessibleForFree: true,
		publisher: { '@id': `${siteMeta.siteUrl}/#organization` },
		author: author
			? { '@id': `${new URL(author.path, `${siteMeta.siteUrl}/`).toString()}#profile` }
			: { '@id': `${siteMeta.siteUrl}/#organization` },
		...(editor ? { editor: { '@id': `${new URL(editor.path, `${siteMeta.siteUrl}/`).toString()}#profile` } } : {}),
		image: imageObjects.map((image) => ({ '@id': image['@id'] })),
	},
	...(breadcrumbs.length
		? [
				{
					'@context': 'https://schema.org',
					'@type': 'BreadcrumbList',
					'@id': breadcrumbId,
					itemListElement: breadcrumbs.map((crumb, index) => ({
						'@type': 'ListItem',
						position: index + 1,
						name: crumb.label,
						item: crumb.href
							? new URL(crumb.href, `${siteMeta.siteUrl}/`).toString()
							: canonicalUrl,
					})),
				},
			]
		: []),
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="icon" type="image/svg+xml" href={siteMeta.faviconPath} />
		<link rel="apple-touch-icon" sizes="180x180" href={siteMeta.appleTouchIconPath} />
		<meta name="theme-color" content={siteMeta.themeColor} />
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
		<meta name="author" content={author?.name ?? siteMeta.editorialTeamName ?? siteMeta.name} />
		<meta name="creator" content={author?.name ?? siteMeta.editorialTeamName ?? siteMeta.name} />
		{editor && <meta name="editor" content={editor.name} />}
		{author && <link rel="author" href={author.path} />}
		<meta property="og:type" content="article" />
		<meta property="og:site_name" content={siteMeta.name} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:image:secure_url" content={imageUrl} />
		<meta property="og:image:type" content={imageType} />
		<meta property="og:image:width" content={String(primaryImage.width)} />
		<meta property="og:image:height" content={String(primaryImage.height)} />
		<meta property="og:image:alt" content={primaryImage.alt ?? siteMeta.ogImageAlt} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		{twitterSite && <meta name="twitter:site" content={twitterSite} />}
		<script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
	</head>
	<body>
		<header class="reference-shell__topbar">
			<div class="reference-shell__topbar-inner">
				<a class="reference-shell__brand" href="/">{siteMeta.name}</a>
				<nav class="reference-shell__nav" aria-label="Reference navigation">
					<a href="/prompts/">Prompt radar</a>
					<a href="/image-prompts/">Image prompts</a>
					<a href="/prompt-library/">Prompt library</a>
					<a href="/tool-comparisons/">Comparisons</a>
				</nav>
			</div>
		</header>
		<main class="reference-shell">
			<div class="reference-shell__inner">
				{breadcrumbs.length > 0 && (
					<nav class="reference-shell__breadcrumbs" aria-label="Breadcrumb">
						{breadcrumbs.map((crumb, index) => (
							<>
								{crumb.href ? <a href={crumb.href}>{crumb.label}</a> : <span>{crumb.label}</span>}
								{index < breadcrumbs.length - 1 && <span aria-hidden="true">/</span>}
							</>
						))}
					</nav>
				)}
				<p class="reference-shell__eyebrow">{eyebrow}</p>
				<h1>{title}</h1>
				<p class="reference-shell__description">{description}</p>
				<slot />
			</div>
		</main>
	</body>
</html>
